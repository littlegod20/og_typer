# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL (required) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=postgres

# Seed sample courses/lessons/text on startup when NODE_ENV=development,
# or set SEED_DATA=true in any environment.
# SEED_DATA=true

# --- Auth / JWT ---
# Use a long random string in production (do not use defaults).
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10

# --- Google OAuth (optional; omit both to disable /auth/google) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- CORS ---
# Comma-separated origins or * (default). For the Vite dev app use:
# CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=*

# --- Rate limiting (general /api/*) ---
# windowMs is in milliseconds. Default in code is very small unless overridden.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# RATE_LIMIT_MESSAGE=Too many requests, please try again later.

# --- Optional: Redis (only if you wire cache.config into the app) ---
# REDIS_URL=redis://localhost:6379
